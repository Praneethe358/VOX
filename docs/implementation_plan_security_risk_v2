### 2.3 — NoSQL Injection Prevention (VULN-04)

#### [NEW] `app/utils/sanitize.py`

Create an input sanitizer that strips MongoDB operators:

```python
"""Input sanitization to prevent NoSQL injection."""
from typing import Any
from fastapi import HTTPException

MONGO_OPERATORS = {"$gt", "$gte", "$lt", "$lte", "$ne", "$in", "$nin",
                   "$or", "$and", "$not", "$nor", "$exists", "$type",
                   "$regex", "$where", "$all", "$elemMatch", "$size",
                   "$expr", "$mod", "$text", "$search"}

def sanitize_value(value: Any) -> Any:
    """Recursively strip MongoDB operators from input."""
    if isinstance(value, dict):
        for key in value:
            if key.startswith("$"):
                raise HTTPException(status_code=400, detail=f"Invalid input: operator '{key}' not allowed")
        return {k: sanitize_value(v) for k, v in value.items()}
    if isinstance(value, list):
        return [sanitize_value(item) for item in value]
    return value

def safe_str(value: Any) -> str:
    """Ensure value is a plain string, reject dicts/lists (injection payloads)."""
    if isinstance(value, (dict, list)):
        raise HTTPException(status_code=400, detail="Invalid input: expected string")
    return str(value).strip()
```

